{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "doctrine/dbal": "^4.2",
        "firebase/php-jwt": "^7.0",
        "inertiajs/inertia-laravel": "^2.0.24",
        "laravel/framework": "^12.61.1",
        "laravel/reverb": "^1.10",
        "laravel/sanctum": "^4.3.2",
        "laravel/tinker": "^2.11.1",
        "league/flysystem-aws-s3-v3": "^3.25",
        "psr/container": "^2.0.1",
        "spatie/laravel-permission": "^6.25",
        "tightenco/ziggy": "^2.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/breeze": "^2.4.2",
        "laravel/pail": "^1.2.7",
        "laravel/pint": "1.20.0",
        "laravel/sail": "^1.63",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9.4",
        "phpunit/phpunit": "^11.5.50"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve --port=8001\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ],
        "test:unit": "bash scripts/test-suite.sh unit",
        "test:contract": "bash scripts/test-suite.sh contract",
        "test:integration": "bash scripts/test-suite.sh integration",
        "test:admin": "bash scripts/test-suite.sh admin",
        "test:migration": "bash scripts/test-suite.sh migration",
        "test:conformance": "bash scripts/test-suite.sh conformance",
        "test:browser": "bash scripts/test-suite.sh browser",
        "test:security": "bash scripts/security/run-security-suite.sh",
        "test:dast": "bash scripts/run-dast-suite.sh",
        "test:full": "bash scripts/test-suite.sh full",
        "test:concurrent": "bash scripts/verify-test-isolation.sh --full"
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "platform": {
            "php": "8.4.99"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
