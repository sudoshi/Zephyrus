{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Hummingbird design tokens — the single cross-platform source of truth (DTCG format). Generated outputs target Jetpack Compose (Android), SwiftUI (iOS), and are diffed against the web (.impeccable/design.json + tailwind.config.js) in CI so the three platforms never drift. Dark is the default theme; .light is the alternate. Encodes the Zephyrus canon: the Two-System Rule, the rationed status ramp, and Figtree 400/500/600.",
  "color": {
    "$type": "color",
    "operational": {
      "$description": "System A — the blue/slate operational palette. Governs every working surface and interaction.",
      "primary": {
        "$description": "The single interactive blue. If it's clickable and important, it's this.",
        "dark": { "$value": "#3B82F6" },
        "light": { "$value": "#2563EB" }
      },
      "primary-hover": {
        "dark": { "$value": "#2563EB" },
        "light": { "$value": "#1D4ED8" }
      },
      "ink": {
        "$description": "Primary text.",
        "dark": { "$value": "#F8FAFC" },
        "light": { "$value": "#1E293B" }
      },
      "ink-muted": {
        "$description": "Secondary text, labels, captions.",
        "dark": { "$value": "#94A3B8" },
        "light": { "$value": "#475569" }
      },
      "surface-base": {
        "$description": "Page field (the lowest layer).",
        "dark": { "$value": "#0F172A" },
        "light": { "$value": "#F8FAFC" }
      },
      "surface-raised": {
        "$description": "Panels / cards. Dark depth comes from this tonal step over surface-base.",
        "dark": { "$value": "#1E293B" },
        "light": { "$value": "#FFFFFF" }
      },
      "surface-hover": {
        "dark": { "$value": "#334155" },
        "light": { "$value": "#F1F5F9" }
      },
      "border": {
        "$description": "Hairline dividers and panel edges.",
        "dark": { "$value": "#334155" },
        "light": { "$value": "#E2E8F0" }
      }
    },
    "brand": {
      "$description": "System B — Acumenus heritage + focus layer ONLY. Never an operational primary (the Two-System Rule).",
      "crimson": {
        "$description": "Master brand identity — wordmark, brand chrome, night-shift status. Used sparingly.",
        "dark": { "$value": "#9B1B30" },
        "light": { "$value": "#B82D42" }
      },
      "gold": {
        "$description": "The focus color — every :focus-visible / focus ring is gold. Never a fill.",
        "dark": { "$value": "#C9A227" },
        "light": { "$value": "#A6791A" }
      }
    },
    "status": {
      "$description": "The rationed four-color vocabulary. ALWAYS paired with a non-color cue (icon/arrow/label). Coral is the most expensive ink — real breaches only.",
      "success": {
        "$description": "On-time, optimal flow, healthy capacity (teal).",
        "dark": { "$value": "#2DD4BF" },
        "light": { "$value": "#059669" }
      },
      "warning": {
        "$description": "Slipping, approaching threshold, moderate acuity (amber).",
        "dark": { "$value": "#E5A84B" },
        "light": { "$value": "#D97706" }
      },
      "critical": {
        "$description": "True threshold breach, bottleneck, high acuity (coral-red). Reserved; never decorative.",
        "dark": { "$value": "#E85A6B" },
        "light": { "$value": "#DC2626" }
      },
      "info": {
        "$description": "Completed states, neutral information, secondary series (sky).",
        "dark": { "$value": "#60A5FA" },
        "light": { "$value": "#0284C7" }
      }
    },
    "on-fill": {
      "$description": "Text/icon color on a solid colored fill. White only on a solid colored fill, never on a surface.",
      "$value": "#FFFFFF"
    }
  },
  "font": {
    "family": {
      "$type": "fontFamily",
      "sans": { "$value": ["Figtree", "ui-sans-serif", "system-ui", "sans-serif"], "$description": "The only family. No serif/mono. Metrics use tabular-nums, not a mono face." }
    },
    "weight": {
      "$type": "fontWeight",
      "$description": "Only 400/500/600 are loaded. No 700/800 (faux-bold).",
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 }
    }
  },
  "typography": {
    "$type": "typography",
    "display": {
      "$description": "Hero metrics / page-level values — read from across the room. Always tabular-nums.",
      "$value": { "fontFamily": "{font.family.sans}", "fontWeight": "{font.weight.semibold}", "fontSize": "28px", "lineHeight": "34px", "letterSpacing": "-0.01em" }
    },
    "headline": {
      "$description": "Section headers, large KPI values.",
      "$value": { "fontFamily": "{font.family.sans}", "fontWeight": "{font.weight.semibold}", "fontSize": "22px", "lineHeight": "28px", "letterSpacing": "0" }
    },
    "title": {
      "$description": "Panel and card titles.",
      "$value": { "fontFamily": "{font.family.sans}", "fontWeight": "{font.weight.semibold}", "fontSize": "16px", "lineHeight": "24px", "letterSpacing": "0" }
    },
    "body": {
      "$description": "Default text.",
      "$value": { "fontFamily": "{font.family.sans}", "fontWeight": "{font.weight.regular}", "fontSize": "14px", "lineHeight": "20px", "letterSpacing": "0" }
    },
    "body-sm": {
      "$description": "Dense secondary text.",
      "$value": { "fontFamily": "{font.family.sans}", "fontWeight": "{font.weight.regular}", "fontSize": "13px", "lineHeight": "18px", "letterSpacing": "0" }
    },
    "label": {
      "$description": "UPPERCASE functional data labels on tiles/columns/axes ONLY — never decorative eyebrows.",
      "$value": { "fontFamily": "{font.family.sans}", "fontWeight": "{font.weight.semibold}", "fontSize": "11px", "lineHeight": "16px", "letterSpacing": "0.05em", "textCase": "uppercase" }
    }
  },
  "spacing": {
    "$type": "dimension",
    "$description": "4px grid.",
    "xs": { "$value": "4px" },
    "sm": { "$value": "8px" },
    "md": { "$value": "16px" },
    "lg": { "$value": "24px" },
    "xl": { "$value": "32px" },
    "touch": { "$value": "44px", "$description": "Minimum tap target (also iOS 44pt / Android 48dp guidance)." }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "6px" },
    "md": { "$value": "8px", "$description": "Buttons, inputs." },
    "lg": { "$value": "12px", "$description": "Panels / cards." },
    "full": { "$value": "9999px" }
  },
  "elevation": {
    "$type": "shadow",
    "$description": "Quiet-Lift. Resting calm; lift only on interaction. Dark prefers tonal step over shadow.",
    "resting-light": { "$value": { "offsetX": "0", "offsetY": "1px", "blur": "3px", "spread": "0", "color": "rgba(15,23,42,0.10)" } },
    "hover-light": { "$value": { "offsetX": "0", "offsetY": "4px", "blur": "12px", "spread": "0", "color": "rgba(15,23,42,0.10)" } },
    "hover-dark": { "$value": { "offsetX": "0", "offsetY": "4px", "blur": "12px", "spread": "0", "color": "rgba(0,0,0,0.25)" }, "$description": "The only dark-mode shadow." }
  },
  "motion": {
    "duration": {
      "$type": "duration",
      "fast": { "$value": "100ms", "$description": "Micro-feedback (hover tint, toggles)." },
      "normal": { "$value": "200ms", "$description": "Default state transitions." },
      "slow": { "$value": "300ms", "$description": "Panel lift / surface transitions." }
    },
    "easing": {
      "$type": "cubicBezier",
      "ease-out": { "$value": [0.16, 1, 0.3, 1], "$description": "Default entrances/lifts." },
      "ease-smooth": { "$value": [0.4, 0, 0.2, 1], "$description": "Reversible state changes." },
      "ease-spring": { "$value": [0.34, 1.56, 0.64, 1], "$description": "Restrained emphasis only — used sparingly." }
    }
  },
  "component": {
    "kpiTile": {
      "$description": "Panel + 3px left status stripe (the ONE sanctioned colored side-accent), always backed by arrow + label + matching data-color.",
      "stripeWidth": { "$type": "dimension", "$value": "3px" },
      "padding": { "$type": "dimension", "$value": "{spacing.md}" },
      "radius": { "$type": "dimension", "$value": "{radius.lg}" }
    },
    "button": {
      "height": { "$type": "dimension", "$value": "36px" },
      "radius": { "$type": "dimension", "$value": "{radius.md}" },
      "paddingX": { "$type": "dimension", "$value": "{spacing.md}" }
    },
    "focusRing": {
      "$description": "Gold, 2px, 2px offset — on every interactive element.",
      "width": { "$type": "dimension", "$value": "2px" },
      "offset": { "$type": "dimension", "$value": "2px" },
      "color": { "$type": "color", "$value": "{color.brand.gold.dark}" }
    }
  }
}
