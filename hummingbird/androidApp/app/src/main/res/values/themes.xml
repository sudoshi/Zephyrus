<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Compose owns all styling; this platform theme just sets a dark window + status bar
         so launch is dark-default and we avoid an AppCompat dependency. -->
    <style name="Theme.Hummingbird" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">#0F172A</item>
        <item name="android:statusBarColor">#0F172A</item>
        <item name="android:navigationBarColor">#0F172A</item>
    </style>
</resources>
