# Vite PRODUCTION-mode client env (loaded by `vite build`, ignored by `npm run dev`).
#
# deploy.sh builds the frontend in the DEV tree, so without this file the dev
# .env's localhost Reverb endpoint gets baked into the prod bundle and the
# browser tries wss://localhost:8080 (broken WebSocket, silent because the
# cockpit falls back to SSE/polling). These four values are the ONLY
# import.meta.env.VITE_* vars the app reads, and all are public by design:
# the Reverb app key is a public routing key, hardcoded in the mobile client
# (never change it), and the wstunnel host/port/scheme are what any browser
# sees anyway. NO secrets may ever be added to this file — it is git-tracked.
VITE_REVERB_APP_KEY=zephyrus-key
VITE_REVERB_HOST=zephyrus.acumenus.net
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
