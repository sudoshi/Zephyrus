APP_NAME=Zephyrus
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Remote PostgreSQL database connection
DB_CONNECTION=pgsql
DB_HOST=demo.zephyrus.care
DB_PORT=5432
DB_DATABASE=zephyrus
DB_USERNAME=postgres
DB_PASSWORD=
DB_SCHEMA=prod

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

RESEND_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

BROADCAST_CONNECTION=reverb

# App credentials. KEY is public (it appears in the ws:// URL) and is hardcoded in
# the Hummingbird mobile build, so keep it "zephyrus-key". SECRET is server-only —
# generate a strong value in production (e.g. `openssl rand -hex 24`).
REVERB_APP_ID=zephyrus
REVERB_APP_KEY=zephyrus-key
REVERB_APP_SECRET=zephyrus-secret

# Broadcaster TRIGGER target (where the app POSTs events). In production set this to
# the LOCAL daemon (127.0.0.1) so a publish never hairpins out through the TLS edge.
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

# Where the Reverb daemon binds. Apache mod_proxy_wstunnel fronts /app -> here.
REVERB_SERVER_HOST=127.0.0.1
REVERB_SERVER_PORT=8080

# PUBLIC endpoint advertised to mobile/web clients (the TLS host Apache terminates).
# Leave unset in local dev — it falls back to REVERB_HOST/PORT/SCHEME above.
# In production: REVERB_PUBLIC_HOST=zephyrus.acumenus.net / PORT=443 / SCHEME=https.
REVERB_PUBLIC_HOST="${REVERB_HOST}"
REVERB_PUBLIC_PORT="${REVERB_PORT}"
REVERB_PUBLIC_SCHEME="${REVERB_SCHEME}"

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_PUBLIC_HOST}"
VITE_REVERB_PORT="${REVERB_PUBLIC_PORT}"
VITE_REVERB_SCHEME="${REVERB_PUBLIC_SCHEME}"

# Authentik OIDC (ships disabled; enable after the zephyrus-oidc app + secrets exist)
OIDC_ENABLED=false
OIDC_DISCOVERY_URL=https://auth.acumenus.net/application/o/zephyrus-oidc/.well-known/openid-configuration
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://zephyrus.acumenus.net/auth/oidc/callback
OIDC_ALLOWED_GROUPS="Zephyrus Users"
OIDC_ADMIN_GROUPS="Zephyrus Admins"

# Eddy — Process-Aware AI Agent (ships DISABLED + LOCAL-ONLY; enable after the
# eddy service + a BAA-covered provider policy exist). The browser never calls
# Eddy directly. Provider secrets (ANTHROPIC_API_KEY etc.) are read ONLY by the
# eddy service from its own env — never expose them to Vite/the client.
EDDY_ENABLED=false
EDDY_BASE_URL=http://eddy:8000             # dev (compose); prod=http://127.0.0.1:8001 behind Apache ProxyPass /eddy/
EDDY_PORT=8090                              # docker-compose host port
EDDY_TIMEOUT_SECONDS=30
EDDY_SHARED_SECRET=                         # HMAC for Laravel<->Eddy request bodies
EDDY_CALLBACK_TOKEN=                        # bearer Eddy uses on non-user telemetry callbacks
EDDY_ALLOW_CLOUD=false                      # master kill-switch for any frontier egress
EDDY_DEFAULT_PROVIDER_MODE=local_first
EDDY_PHI_DETECTION_ENABLED=true
EDDY_PHI_BLOCK_ON_DETECTION=true
EDDY_CLOUD_MONTHLY_BUDGET_USD=500.0
EDDY_CLOUD_BUDGET_CUTOFF_THRESHOLD=0.95
EDDY_CLOUD_BUDGET_ALERT_THRESHOLDS=0.50,0.80,0.95

# --- read ONLY by the eddy service (never by Laravel/Vite) ---
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434
EDDY_OLLAMA_MODEL=puyangwang/medgemma-27b-it:q4_0
# Pre-load the local model at boot. Recommended TRUE in prod: a cold 27B q4_0 load
# (~75-180s) otherwise lands on the first user request and can exceed the adapter
# timeout; once warm, replies are ~6s.
EDDY_WARMUP_ON_STARTUP=true
EDDY_AGENT_MODEL=claude-opus-4-8
EDDY_AGENT_EFFORT=xhigh
EDDY_CLOUD_CHAT_MODEL=claude-sonnet-4-6
EDDY_AGENT_LOCAL_BASE_URL=http://claude-router:8787   # Anthropic-compatible proxy -> Ollama
EDDY_AGENT_LOCAL_MODEL=qwen2.5-coder:32b              # tool-calling local model (NOT MedGemma)
EDDY_AGENT_MAX_TURNS=24
EDDY_AGENT_MAX_BUDGET_USD=5.0
EDDY_AGENT_APPROVAL_TIMEOUT_SECONDS=600

# Zephyrus 2.0 cockpit (P1 serving layer, P2 overview)
COCKPIT_OVERVIEW_ENABLED=true               # false = /dashboard falls back to the pre-2.0 four-band layout (rollback path)
COCKPIT_OVERVIEW_REDIRECTS=true             # false = the five legacy /dashboard/* overviews serve their original pages again (P4a rollback)
COCKPIT_HIDE_DEMO_DOMAINS=false             # true on real deployments: hide all-demo domains (Quality/Service/Financial) until live
COCKPIT_METRIC_VALUES_RETENTION_DAYS=90     # ops.metric_values snapshot-grain retention (aligned to TREND_DAYS)
COCKPIT_ALERT_OPEN_HOLDS=2                  # P6 flap-damping: consecutive alerting snapshots before an alert OPENS
COCKPIT_ALERT_CLEAR_HOLDS=3                 # P6 flap-damping: consecutive normal snapshots before an open alert CLEARS
COCKPIT_ALERT_RECONCILE_INTERVAL=30         # seconds; burst rebuilds inside this window serve reads without counting holds
